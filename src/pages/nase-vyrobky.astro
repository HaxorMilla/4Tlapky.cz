---
import Layout from "~/layouts/Layout.astro";
import Section from "~/components/Section.astro";
import Container from "~/components/Container.astro";
import Heading from "~/components/Heading.astro";
import { Image } from "astro:assets";

// 1. IMPORTY OBRÁZKŮ
import img1 from "~/assets/images/1.jpg";
import img2 from "~/assets/images/2.jpg";
import img3 from "~/assets/images/3.jpg";
import img4 from "~/assets/images/4.jpg";
import img5 from "~/assets/images/5.jpg";
import img6 from "~/assets/images/6.jpg";
import img7 from "~/assets/images/7.jpg";
import img8 from "~/assets/images/8.jpg";
import img9 from "~/assets/images/9.jpg";
import img10 from "~/assets/images/10.jpg";
import img11 from "~/assets/images/11.jpg";
import img12 from "~/assets/images/12.jpg";
import img13 from "~/assets/images/13.jpg";
import img14 from "~/assets/images/14.jpg";

// 2. DEFINICE PRODUKTŮ
const produkty = [
	{ jmeno: "TORNADO Jehně", popis: "", cena: "449 Kč", foto: img1 },
	{ jmeno: "TORNADO Pstruh", popis: "", cena: "549 Kč", foto: img2 },
	{ jmeno: "TORNADO Losos", popis: "", cena: "590 Kč", foto: img3 },
	{ jmeno: "TORNADO Králík", popis: "", cena: "599 Kč", foto: img4 },
	{ jmeno: "TORNADO Krocan", popis: "", cena: "610 Kč", foto: img5 },
	{ jmeno: "TORNADO Krocan", popis: "", cena: "630 Kč", foto: img6 },
	{ jmeno: "TORNADO Krocan", popis: "", cena: "640 Kč", foto: img7 },
	{ jmeno: "TORNADO Jehně", popis: "", cena: "620 Kč", foto: img8 },
	{ jmeno: "TORNADO Krocan", popis: "", cena: "580 Kč", foto: img9 },
	{ jmeno: "TORNADO Jehně", popis: "", cena: "650 Kč", foto: img10 },
	{ jmeno: "TORNADO Losos", popis: "", cena: "690 Kč", foto: img11 },
	{ jmeno: "TORNADO Losos", popis: "", cena: "645 Kč", foto: img12 },
	{ jmeno: "TORNADO Losos", popis: "", cena: "430 Kč", foto: img13 },
	{ jmeno: "TORNADO Kuře", popis: "", cena: "480 Kč", foto: img14 },
];
---

<Layout title="TORNADO – ŠPIČKOVÁ VÝŽIVA PRO KAŽDÉHO PSA | 4 TLAPKY" pageTitle="Naše výrobky">
	<Section>
		<Container>
			<Heading>
				<h1 slot="heading-title" class="h2 text-fuchsia-600 uppercase">🌪️TORNADO🌪️</h1>
				<div slot="heading-content" class="mt-6">
					<p class="text-2xl font-bold text-gray-800 mb-4 text-left">
						Hledáte opravdu kvalitní granule pro svého psa?
					</p>
					<p class="text-lg text-gray-600 mb-6 text-left">
						Představujeme <strong>TORNADO</strong> – superprémiové krmivo pro štěňata, dospělé i starší psy všech plemen. 
						Všechny produkty jsou k dostání u nás v prodejně.
					</p>

					{/* OPRAVA: Změněno md: na lg: aby se sloupce na mobilu nehádaly */}
					<div class="grid grid-cols-1 lg:grid-cols-2 gap-4 text-left max-w-4xl mx-auto bg-fuchsia-50 p-6 md:p-8 rounded-3xl border border-fuchsia-100">
						<ul class="space-y-3 text-gray-700">
							<li class="flex items-start gap-3">
								<span class="shrink-0 text-xl">✅</span> 
								<span><span class="font-bold">65 %</span> živočišných bílkovin</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="shrink-0 text-xl">✅</span> 
								<span>Bez obilovin <span class="italic text-sm">(grain-free)</span></span>
							</li>
							<li class="flex items-start gap-3">
								<span class="shrink-0 text-xl">✅</span> 
								<span>Maso z volného chovu a rybářství</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="shrink-0 text-xl">✅</span> 
								<span>Technologie <span class="font-bold">Freshtrusion (82 °C)</span></span>
							</li>
						</ul>
						<ul class="space-y-3 text-gray-700">
							<li class="flex items-start gap-3">
								<span class="shrink-0 text-xl">🦴</span> 
								<span>Obohaceno o <span class="font-bold">Superfoods</span> směs</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="shrink-0 text-xl">🌿</span> 
								<span>Antioxidanty a Omega 3</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="shrink-0 text-xl">🍎</span> 
								<span>Vitamíny (A, B3, B9, C, K)</span>
							</li>
							<li class="flex items-start gap-3">
								<span class="shrink-0 text-xl">💪</span> 
								<span>Minerály (železo, vápník, draslík)</span>
							</li>
						</ul>
					</div>

					<p class="mt-8 text-xl font-bold text-teal-600 italic text-left">
						Dopřej svému psovi výživu, kterou si zaslouží!
					</p>
				</div>
			</Heading>

			<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 xl:grid-cols-4 gap-8 mt-16">
				{produkty.map((produkt) => (
					<div class="bg-white rounded-2xl shadow-md overflow-hidden border border-gray-100 flex flex-col transition-all hover:shadow-xl hover:-translate-y-1">
						
						<div class="aspect-[3/4] overflow-hidden bg-[#0c0c0c]">
							<Image 
								src={produkt.foto} 
								alt={produkt.jmeno} 
								class="w-full h-full object-contain" 
								width={600}
								height={800}
							/>
						</div>
						
						<div class="p-6 flex flex-col flex-grow bg-white text-center">
							<h3 class="font-bold text-xl mb-1 text-gray-900">{produkt.jmeno}</h3>
							{produkt.popis && <p class="text-gray-500 text-sm mb-4 italic leading-relaxed">{produkt.popis}</p>}
							
							<div class="flex items-center justify-center mt-auto pt-4 border-t border-gray-50">
								<span class="text-3xl font-extrabold text-fuchsia-600">{produkt.cena}</span>
							</div>
						</div>
					</div>
				))}
			</div>
		</Container>
	</Section>
</Layout>
